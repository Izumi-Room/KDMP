<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login | AIWarung</title>
  
  <!-- Bootstrap 5 CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  
  <!-- Font -->
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <style>
    body {
      font-family: 'Outfit', sans-serif;
      background: radial-gradient(circle at 10% 20%, rgb(15, 23, 42) 0%, rgb(30, 41, 59) 90%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0;
      overflow: hidden;
    }
    
    .login-container {
      width: 100%;
      max-width: 420px;
      padding: 15px;
      z-index: 10;
    }

    .login-glass-card {
      background: rgba(30, 41, 59, 0.45);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 24px;
      box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
      padding: 40px;
      color: #fff;
    }

    .login-logo {
      font-size: 32px;
      font-weight: 700;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      margin-bottom: 30px;
    }

    .login-logo i {
      color: #3b82f6;
      filter: drop-shadow(0 0 10px rgba(59, 130, 246, 0.5));
    }

    .form-floating-custom {
      position: relative;
      margin-bottom: 20px;
    }

    .form-floating-custom input {
      background: rgba(15, 23, 42, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: #fff;
      padding: 14px 16px 14px 44px;
      border-radius: 12px;
      width: 100%;
      box-sizing: border-box;
      font-size: 15px;
      transition: all 0.3s ease;
    }

    .form-floating-custom input:focus {
      background: rgba(15, 23, 42, 0.8);
      border-color: #3b82f6;
      box-shadow: 0 0 12px rgba(59, 130, 246, 0.25);
      outline: none;
    }

    .form-floating-custom i {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: rgba(255, 255, 255, 0.4);
      font-size: 18px;
    }

    .btn-login {
      background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
      border: none;
      border-radius: 12px;
      padding: 14px;
      color: #fff;
      font-weight: 600;
      font-size: 16px;
      transition: all 0.2s ease;
      box-shadow: 0 4px 15px rgba(37, 99, 235, 0.4);
    }

    .btn-login:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(37, 99, 235, 0.6);
    }

    .btn-login:active {
      transform: translateY(0);
    }

    /* Abstract shapes background */
    .shape {
      position: absolute;
      border-radius: 50%;
      filter: blur(100px);
      z-index: 1;
    }
    .shape-1 {
      width: 300px;
      height: 300px;
      background: rgba(59, 130, 246, 0.3);
      top: 10%;
      left: 15%;
    }
    .shape-2 {
      width: 400px;
      height: 400px;
      background: rgba(16, 185, 129, 0.2);
      bottom: 10%;
      right: 15%;
    }
  </style>
</head>
<body>
  <!-- Decorative background elements -->
  <div class="shape shape-1"></div>
  <div class="shape shape-2"></div>

  <div class="login-container">
    <div class="login-glass-card text-center fade-in">
      <div class="login-logo">
        <i class="bi bi-shop"></i>
        <span>AIWarung</span>
      </div>
      
      <p class="text-white-50 mb-4" style="font-size: 14px;">Masukkan kredensial Anda untuk masuk ke sistem warung</p>

      <% if (error) { %>
        <div class="alert alert-danger border-0 text-start py-2 px-3 mb-4 rounded-3 d-flex align-items-center" style="background: rgba(239, 68, 68, 0.2); color: #fca5a5; font-size: 13px;">
          <i class="bi bi-exclamation-triangle-fill me-2 fs-6"></i>
          <div><%= error %></div>
        </div>
      <% } %>

      <form action="/login" method="POST" autocomplete="off">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-floating-custom">
          <i class="bi bi-person"></i>
          <input type="text" name="username" placeholder="Username / ID User" required value="<%= old.username || '' %>">
        </div>

        <div class="form-floating-custom">
          <i class="bi bi-lock"></i>
          <input type="password" name="password" placeholder="Password" required>
        </div>

        <button type="submit" class="btn btn-login w-100 mt-2">
          Masuk Aplikasi
          <i class="bi bi-box-arrow-in-right ms-1"></i>
        </button>
      </form>
    </div>
  </div>
</body>
</html>
