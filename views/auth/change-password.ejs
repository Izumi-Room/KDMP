<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="main-wrapper">
  <div class="page-header-nav">
    <h1 class="h3 fw-bold mb-0">Keamanan</h1>
  </div>

  <div class="row fade-in">
    <div class="col-md-6 col-lg-5">
      <div class="glass-card p-4">
        <h2 class="h5 fw-bold mb-3 d-flex align-items-center gap-2">
          <i class="bi bi-shield-lock text-primary"></i>
          <span>Ubah Password Akun</span>
        </h2>
        
        <%- include('../partials/alerts') %>

        <form action="/change-password" method="POST">
          <div class="mb-3">
            <label class="form-label fw-semibold text-secondary">Password Saat Ini</label>
            <input type="password" name="current_password" class="form-control form-control-custom <%= errors.current_password ? 'is-invalid' : '' %>" required>
            <% if (errors.current_password) { %>
              <div class="invalid-feedback"><%= errors.current_password %></div>
            <% } %>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold text-secondary">Password Baru</label>
            <input type="password" name="password" class="form-control form-control-custom <%= errors.password ? 'is-invalid' : '' %>" required>
            <% if (errors.password) { %>
              <div class="invalid-feedback"><%= errors.password %></div>
            <% } %>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold text-secondary">Konfirmasi Password Baru</label>
            <input type="password" name="password_confirmation" class="form-control form-control-custom <%= errors.password_confirmation ? 'is-invalid' : '' %>" required>
            <% if (errors.password_confirmation) { %>
              <div class="invalid-feedback"><%= errors.password_confirmation %></div>
            <% } %>
          </div>

          <button type="submit" class="btn btn-primary-custom w-100">
            Perbarui Password
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
