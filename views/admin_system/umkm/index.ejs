<%- include('../../partials/header') %>
<%- include('../../partials/sidebar') %>

<div class="main-wrapper">
  <div class="page-header-nav">
    <div>
      <h1 class="h3 fw-bold mb-0">Kelola UMKM</h1>
      <p class="text-secondary mb-0" style="font-size: 14px;">Administrasi data warung UMKM dan akun pengelolanya</p>
    </div>
    <div>
      <a href="/admin-system/umkm/create" class="btn btn-primary-custom d-flex align-items-center gap-2">
        <i class="bi bi-plus-circle"></i>
        <span>Tambah UMKM</span>
      </a>
    </div>
  </div>

  <%- include('../../partials/alerts') %>

  <!-- Search & Filter Area -->
  <div class="glass-card p-3 mb-4 fade-in">
    <form action="/admin-system/umkm" method="GET" class="row g-3 align-items-center">
      <div class="col-md-6 col-lg-4">
        <div class="input-group">
          <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-secondary"></i></span>
          <input type="text" name="search" class="form-control form-control-custom border-start-0 ps-0" placeholder="Cari nama UMKM atau alamat..." value="<%= search %>">
        </div>
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-primary-custom">Filter</button>
        <% if (search) { %>
          <a href="/admin-system/umkm" class="btn btn-outline-secondary ms-1" style="border-radius: 8px; padding: 10px 20px;">Reset</a>
        <% } %>
      </div>
    </form>
  </div>

  <!-- UMKM Table -->
  <div class="glass-card fade-in">
    <div class="table-responsive">
      <table class="table custom-table mb-0">
        <thead>
          <tr>
            <th>No</th>
            <th>Nama UMKM</th>
            <th>Alamat</th>
            <th>Telepon</th>
            <th>Admin (ID User)</th>
            <th>Status Akun</th>
            <th class="text-end">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (umkms.length === 0) { %>
            <tr>
              <td colspan="7" class="text-center text-muted">Data UMKM tidak ditemukan.</td>
            </tr>
          <% } else { %>
            <% umkms.forEach((umkm, idx) => { %>
              <% const admin = umkm.users?.[0]; %>
              <% const numberIndex = (currentPage - 1) * 10 + idx + 1; %>
              <tr>
                <td><%= numberIndex %></td>
                <td>
                  <div class="fw-bold"><%= umkm.nama_umkm %></div>
                  <div class="text-secondary" style="font-size: 11px;">Daftar: <%= new Date(umkm.created_at).toLocaleDateString('id-ID', {day: 'numeric', month: 'long', year: 'numeric'}) %></div>
                </td>
                <td><%= umkm.alamat || '-' %></td>
                <td><%= umkm.telepon || '-' %></td>
                <td>
                  <% if (admin) { %>
                    <div class="fw-semibold text-dark"><%= admin.name %></div>
                    <div class="text-secondary" style="font-size: 11px;"><i class="bi bi-person me-1"></i><%= admin.username %></div>
                  <% } else { %>
                    <span class="text-muted">-</span>
                  <% } %>
                </td>
                <td>
                  <% if (admin) { %>
                    <form action="/admin-system/user/<%= admin.id %>/toggle-status" method="POST" id="toggle-form-<%= admin.id %>" class="m-0">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <label class="switch">
                        <input type="checkbox" class="status-toggle-checkbox" <%= admin.status ? 'checked' : '' %> data-form-id="toggle-form-<%= admin.id %>">
                        <span class="slider"></span>
                      </label>
                    </form>
                  <% } else { %>
                    <span class="text-muted">-</span>
                  <% } %>
                </td>
                <td class="text-end">
                  <div class="d-flex justify-content-end gap-2">
                    <a href="/admin-system/umkm/<%= umkm.id %>/edit" class="btn btn-outline-warning btn-sm border-0" data-bs-toggle="tooltip" title="Edit UMKM">
                      <i class="bi bi-pencil-square"></i>
                    </a>
                    
                    <form action="/admin-system/umkm/<%= umkm.id %>/delete" method="POST" class="m-0 delete-umkm-form">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="btn btn-outline-danger btn-sm border-0" data-bs-toggle="tooltip" title="Hapus UMKM">
                        <i class="bi bi-trash-fill"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Pagination Footer -->
    <% if (totalPages > 1) { %>
      <div class="card-footer bg-white border-0 py-3 d-flex justify-content-center">
        <nav aria-label="Page navigation">
          <ul class="pagination pagination-sm mb-0">
            <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
              <a class="page-link" href="/admin-system/umkm?page=<%= currentPage - 1 %>&search=<%= search %>">Sebelumnya</a>
            </li>
            <% for(let i = 1; i <= totalPages; i++) { %>
              <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                <a class="page-link" href="/admin-system/umkm?page=<%= i %>&search=<%= search %>"><%= i %></a>
              </li>
            <% } %>
            <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
              <a class="page-link" href="/admin-system/umkm?page=<%= currentPage + 1 %>&search=<%= search %>">Selanjutnya</a>
            </li>
          </ul>
        </nav>
      </div>
    <% } %>
  </div>
</div>

<script>
  document.querySelectorAll('.status-toggle-checkbox').forEach(item => {
    item.addEventListener('change', function() {
      const formId = this.getAttribute('data-form-id');
      document.getElementById(formId).submit();
    });
  });

  document.querySelectorAll('.delete-umkm-form').forEach(item => {
    item.addEventListener('submit', function(e) {
      if (!confirm('Apakah Anda yakin ingin menghapus UMKM ini? Seluruh data barang, transaksi, dan pegawai di bawah UMKM ini akan dihapus permanen!')) {
        e.preventDefault();
      }
    });
  });
</script>

<%- include('../../partials/footer') %>
