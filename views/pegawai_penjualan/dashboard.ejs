<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="main-wrapper">
  <div class="page-header-nav">
    <div>
      <h1 class="h3 fw-bold mb-0">Dashboard Kasir</h1>
      <p class="text-secondary mb-0" style="font-size: 14px;">Selamat bekerja! Pantau transaksi checkout penjualan Anda</p>
    </div>
    <div>
      <a href="/kasir/transaksi" class="btn btn-primary-custom d-flex align-items-center gap-2">
        <i class="bi bi-cart-plus-fill"></i>
        <span>Buka POS Checkout</span>
      </a>
    </div>
  </div>

  <%- include('../partials/alerts') %>

  <!-- Stats Grid -->
  <div class="row g-4 mb-4 fade-in">
    <div class="col-md-6 col-lg-4">
      <div class="glass-card p-3 d-flex align-items-center gap-3">
        <div class="stat-card-icon icon-blue">
          <i class="bi bi-receipt-cutoff"></i>
        </div>
        <div>
          <h5 class="text-secondary mb-0" style="font-size: 13px;">Jumlah Penjualan Anda</h5>
          <div class="fs-4 fw-bold text-dark"><%= totalCount %> Transaksi</div>
        </div>
      </div>
    </div>
    
    <div class="col-md-6 col-lg-4">
      <div class="glass-card p-3 d-flex align-items-center gap-3">
        <div class="stat-card-icon icon-green">
          <i class="bi bi-currency-dollar"></i>
        </div>
        <div>
          <h5 class="text-secondary mb-0" style="font-size: 13px;">Total Omset Kasir Anda</h5>
          <div class="fs-4 fw-bold text-dark">
            Rp <%= Number(totalSum).toLocaleString('id-ID') %>
          </div>
        </div>
      </div>
    </div>

    <!-- Low Stock warning banner -->
    <div class="col-md-12 col-lg-4">
      <% if (lowStock.length > 0) { %>
        <div class="alert alert-warning border-0 shadow-sm rounded-3 d-flex align-items-center mb-0 h-100" role="alert">
          <i class="bi bi-exclamation-triangle-fill fs-3 me-3 text-warning"></i>
          <div>
            <div class="fw-bold">Peringatan Stok Kritis!</div>
            <div style="font-size: 12px;"><%= lowStock.length %> produk di toko memiliki persediaan menipis. Harap hubungi Admin UMKM.</div>
          </div>
        </div>
      <% } else { %>
        <div class="alert alert-success border-0 shadow-sm rounded-3 d-flex align-items-center mb-0 h-100" role="alert">
          <i class="bi bi-check-circle-fill fs-3 me-3 text-success"></i>
          <div>
            <div class="fw-bold">Stok Aman</div>
            <div style="font-size: 12px;">Persediaan stok semua produk di gudang dalam keadaan optimal.</div>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Recent Sales Table -->
  <div class="glass-card p-4 fade-in">
    <h3 class="h6 fw-bold text-secondary mb-3">5 Transaksi Terakhir Anda</h3>
    <div class="table-responsive">
      <table class="table custom-table mb-0">
        <thead>
          <tr>
            <th>No</th>
            <th>No Faktur</th>
            <th>Tanggal</th>
            <th>Barang Belanja (Qty)</th>
            <th>Total Belanja</th>
            <th>Bayar</th>
            <th>Kembali</th>
            <th class="text-end">Cetak Struk</th>
          </tr>
        </thead>
        <tbody>
          <% if (recentSales.length === 0) { %>
            <tr>
              <td colspan="8" class="text-center text-muted">Anda belum mencatat penjualan hari ini.</td>
            </tr>
          <% } else { %>
            <% recentSales.forEach((sale, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td class="fw-semibold text-primary"><%= sale.no_faktur %></td>
                <td><%= sale.tanggal %></td>
                <td>
                  <ul class="list-unstyled mb-0" style="font-size: 12px;">
                    <% sale.details.forEach(det => { %>
                      <li><%= det.barang?.nama_barang || 'Barang Dihapus' %> (<%= det.qty %> <%= det.barang?.satuan || 'pcs' %>)</li>
                    <% }) %>
                  </ul>
                </td>
                <td class="fw-bold text-success">Rp <%= Number(sale.total_harga).toLocaleString('id-ID') %></td>
                <td>Rp <%= Number(sale.bayar || 0).toLocaleString('id-ID') %></td>
                <td>Rp <%= Number(sale.kembali || 0).toLocaleString('id-ID') %></td>
                <td class="text-end">
                  <a href="/kasir/transaksi/<%= sale.id %>/print" target="_blank" class="btn btn-outline-primary btn-sm border-0" data-bs-toggle="tooltip" title="Cetak Struk">
                    <i class="bi bi-printer-fill"></i>
                  </a>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
