<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="main-wrapper">
  <div class="page-header-nav mb-3">
    <div>
      <h1 class="h3 fw-bold mb-0">POS Terminal Penjualan</h1>
      <p class="text-secondary mb-0" style="font-size: 13px;">Kelola antrean kasir cepat, scan, and checkout pembayaran pelanggan</p>
    </div>
    <div>
      <a href="/kasir/dashboard" class="btn btn-outline-secondary" style="border-radius: 8px;">
        <i class="bi bi-speedometer2 me-1"></i> Dashboard
      </a>
    </div>
  </div>

  <div class="pos-container fade-in">
    <!-- Left Pane: Product Catalog -->
    <div class="pos-catalog">
      <div class="glass-card p-3 mb-3">
        <div class="input-group">
          <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-secondary"></i></span>
          <input type="text" id="catalogSearch" class="form-control form-control-custom border-start-0 ps-0" placeholder="Cari nama barang atau kode barcode...">
        </div>
      </div>

      <div class="row g-3" id="catalogGrid">
        <% if (barang.length === 0) { %>
          <div class="col-12 text-center text-muted py-5">
            Belum ada barang di katalog stok UMKM.
          </div>
        <% } else { %>
          <% barang.forEach(item => { %>
            <div class="col-sm-6 col-md-4 product-card-wrapper" data-name="<%= item.nama_barang.toLowerCase() %>" data-code="<%= item.kode_barang.toLowerCase() %>">
              <div class="glass-card p-3 h-100 d-flex flex-column justify-content-between">
                <div>
                  <span class="text-secondary" style="font-size: 11px;"><%= item.kode_barang %></span>
                  <h4 class="h6 fw-bold text-dark mt-1 mb-1 product-title"><%= item.nama_barang %></h4>
                  <div class="text-secondary" style="font-size: 12px;">Ukuran: <%= item.ukuran || '-' %></div>
                </div>
                <div class="mt-3">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-secondary" style="font-size: 12px;">Stok: <%= item.stok %> <%= item.satuan %></span>
                  </div>
                  
                  <!-- Numeric Price Input for the clerk to input -->
                  <div class="input-group input-group-sm mb-2">
                    <span class="input-group-text bg-light" style="font-size: 11px;">Rp</span>
                    <input type="number" id="price-input-<%= item.id %>" class="form-control text-end" placeholder="Harga Jual" min="0" style="font-size: 11px;">
                  </div>

                  <button type="button" class="btn btn-primary btn-sm w-100 d-flex align-items-center justify-content-center gap-1 add-to-cart-btn" 
                    onclick="addToCart(<%= item.id %>, '<%= item.nama_barang %>', '<%= item.satuan %>', <%= item.stok %>);"
                    <%= item.stok <= 0 ? 'disabled' : '' %>>
                    <i class="bi bi-plus-lg"></i>
                    <span><%= item.stok <= 0 ? 'Habis' : 'Tambah' %></span>
                  </button>
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <!-- Right Pane: Interactive Cart Checkout Drawer -->
    <div class="pos-cart">
      <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
        <h3 class="h6 fw-bold text-secondary mb-0"><i class="bi bi-cart3 me-2"></i>Keranjang Belanja</h3>
        <button type="button" class="btn btn-sm btn-outline-danger border-0" onclick="clearCart();">Kosongkan</button>
      </div>

      <!-- Items Scroll List -->
      <div class="pos-cart-items" id="cartContainer">
        <div class="text-center text-muted py-5" id="emptyCartMessage">
          <i class="bi bi-basket2 fs-2 d-block mb-2 text-white-50"></i>
          Keranjang kosong
        </div>
        <!-- Dynamic items injected here -->
      </div>

      <!-- Totals & Payment Checkout -->
      <div class="pos-cart-summary">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <span class="fw-semibold text-secondary">Total Belanja:</span>
          <span class="fs-4 fw-bold text-primary" id="cartTotalLabel">Rp 0</span>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold text-secondary" style="font-size: 13px;">Uang Bayar (Tunai):</label>
          <div class="input-group">
            <span class="input-group-text bg-white border-end-0">Rp</span>
            <input type="number" id="cashPaidInput" class="form-control form-control-custom border-start-0 ps-0" placeholder="0" min="0" oninput="calculateChange();">
          </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4">
          <span class="fw-semibold text-secondary" style="font-size: 13px;">Uang Kembali:</span>
          <span class="fw-bold text-success fs-5" id="changeAmountLabel">Rp 0</span>
        </div>

        <button type="button" class="btn btn-primary-custom w-100 py-3 fw-bold" id="checkoutBtn" onclick="submitCheckout();">
          <i class="bi bi-credit-card-fill me-1"></i> Selesaikan Transaksi
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Checkout Success Modal -->
<div class="modal fade" id="checkoutSuccessModal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow rounded-4">
      <div class="modal-body text-center p-5">
        <div class="text-success mb-3">
          <i class="bi bi-check-circle-fill" style="font-size: 64px;"></i>
        </div>
        <h4 class="fw-bold text-dark mb-1">Transaksi Berhasil!</h4>
        <p class="text-secondary mb-4" id="modalInvoiceNumber">Nomor Faktur: INV-XXXX</p>
        
        <div class="p-3 bg-light rounded-3 mb-4">
          <div class="d-flex justify-content-between mb-1" style="font-size: 13px;">
            <span class="text-secondary">Total Belanja:</span>
            <span class="fw-bold text-dark" id="modalTotalAmount">Rp 0</span>
          </div>
          <div class="d-flex justify-content-between mb-1" style="font-size: 13px;">
            <span class="text-secondary">Uang Bayar:</span>
            <span class="fw-bold text-dark" id="modalCashPaid">Rp 0</span>
          </div>
          <div class="d-flex justify-content-between" style="font-size: 13px;">
            <span class="text-secondary">Kembali:</span>
            <span class="fw-bold text-success" id="modalChangeAmount">Rp 0</span>
          </div>
        </div>

        <div class="d-grid gap-2">
          <a href="#" id="printInvoiceBtn" target="_blank" class="btn btn-primary py-2 fw-semibold">
            <i class="bi bi-printer me-1"></i> Cetak Struk Belanja
          </a>
          <button type="button" class="btn btn-outline-secondary py-2" data-bs-dismiss="modal" onclick="resetPOS();">
            Buka Transaksi Baru
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- POS Interactive JS -->
<script>
  let cart = [];

  // Search filter
  document.getElementById('catalogSearch').addEventListener('input', function(e) {
    const q = e.target.value.toLowerCase();
    const cards = document.querySelectorAll('.product-card-wrapper');
    cards.forEach(card => {
      const name = card.getAttribute('data-name');
      const code = card.getAttribute('data-code');
      if (name.includes(q) || code.includes(q)) {
        card.style.display = 'block';
      } else {
        card.style.display = 'none';
      }
    });
  });

  // Cart operations
  function addToCart(id, name, satuan, maxStok) {
    const priceInput = document.getElementById(`price-input-${id}`);
    const price = parseFloat(priceInput.value);
    
    if (isNaN(price) || price <= 0) {
      alert("Masukkan harga jual barang terlebih dahulu!");
      priceInput.focus();
      return;
    }

    const existingIdx = cart.findIndex(item => item.barang_id === id && item.harga_satuan === price);

    if (existingIdx > -1) {
      if (cart[existingIdx].qty >= maxStok) {
        alert("Kuantitas barang melebihi stok yang tersedia!");
        return;
      }
      cart[existingIdx].qty++;
    } else {
      cart.push({
        barang_id: id,
        nama_barang: name,
        satuan: satuan,
        qty: 1,
        harga_satuan: price,
        maxStok: maxStok
      });
    }

    renderCart();
  }

  function updateQty(index, newQty) {
    const item = cart[index];
    newQty = parseInt(newQty);
    if (newQty <= 0) {
      cart.splice(index, 1);
    } else if (newQty > item.maxStok) {
      alert("Kuantitas barang melebihi stok yang tersedia!");
      return;
    } else {
      item.qty = newQty;
    }
    renderCart();
  }

  function removeFromCart(index) {
    cart.splice(index, 1);
    renderCart();
  }

  function clearCart() {
    cart = [];
    document.getElementById('cashPaidInput').value = '';
    renderCart();
  }

  function renderCart() {
    const container = document.getElementById('cartContainer');
    const emptyMsg = document.getElementById('emptyCartMessage');
    
    if (cart.length === 0) {
      container.innerHTML = '';
      container.appendChild(emptyMsg);
      document.getElementById('cartTotalLabel').innerText = 'Rp 0';
      document.getElementById('changeAmountLabel').innerText = 'Rp 0';
      return;
    }

    if (emptyMsg.parentNode === container) {
      container.innerHTML = '';
    } else {
      container.innerHTML = '';
    }

    let total = 0;
    cart.forEach((item, index) => {
      const subtotal = item.qty * item.harga_satuan;
      total += subtotal;

      const row = document.createElement('div');
      row.className = 'glass-card p-3 mb-2 d-flex justify-content-between align-items-center';
      row.innerHTML = `
        <div class="flex-grow-1" style="max-width: 60%;">
          <div class="fw-bold text-dark text-truncate" style="font-size: 13px;">${item.nama_barang}</div>
          <div class="text-secondary" style="font-size: 11px;">Rp ${item.harga_satuan.toLocaleString('id-ID')} / ${item.satuan}</div>
        </div>
        <div class="d-flex align-items-center gap-2">
          <input type="number" class="form-control text-center py-1 px-2" value="${item.qty}" min="1" max="${item.maxStok}" style="width: 50px; font-size: 12px;" onchange="updateQty(${index}, this.value);">
          <button type="button" class="btn btn-outline-danger btn-sm border-0" onclick="removeFromCart(${index});"><i class="bi bi-trash"></i></button>
        </div>
      `;
      container.appendChild(row);
    });

    document.getElementById('cartTotalLabel').innerText = 'Rp ' + total.toLocaleString('id-ID');
    calculateChange();
  }

  function calculateChange() {
    const total = getCartTotal();
    const paid = parseFloat(document.getElementById('cashPaidInput').value) || 0;
    const change = paid - total;
    
    const label = document.getElementById('changeAmountLabel');
    if (change < 0) {
      label.innerText = 'Rp 0';
      label.className = 'fw-bold text-danger fs-5';
    } else {
      label.innerText = 'Rp ' + change.toLocaleString('id-ID');
      label.className = 'fw-bold text-success fs-5';
    }
  }

  function getCartTotal() {
    return cart.reduce((sum, item) => sum + (item.qty * item.harga_satuan), 0);
  }

  // Submit via fetch API
  function submitCheckout() {
    if (cart.length === 0) {
      alert("Keranjang belanja kosong!");
      return;
    }

    const total = getCartTotal();
    const paid = parseFloat(document.getElementById('cashPaidInput').value) || 0;

    if (paid < total) {
      alert("Uang bayar tidak mencukupi total belanja!");
      return;
    }

    const btn = document.getElementById('checkoutBtn');
    btn.disabled = true;
    btn.innerText = "Memproses...";

    fetch('/kasir/transaksi', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'X-CSRF-Token': '<%= csrfToken %>'
      },
      body: JSON.stringify({
        items: cart,
        total_harga: total,
        bayar: paid
      })
    })
    .then(res => res.json())
    .then(data => {
      btn.disabled = false;
      btn.innerHTML = `<i class="bi bi-credit-card-fill me-1"></i> Selesaikan Transaksi`;

      if (data.success) {
        // Show success modal
        document.getElementById('modalInvoiceNumber').innerText = 'Nomor Faktur: ' + data.no_faktur;
        document.getElementById('modalTotalAmount').innerText = 'Rp ' + data.total.toLocaleString('id-ID');
        document.getElementById('modalCashPaid').innerText = 'Rp ' + data.bayar.toLocaleString('id-ID');
        document.getElementById('modalChangeAmount').innerText = 'Rp ' + data.kembali.toLocaleString('id-ID');
        document.getElementById('printInvoiceBtn').setAttribute('href', `/kasir/transaksi/${data.penjualan_id}/print`);

        const modal = new bootstrap.Modal(document.getElementById('checkoutSuccessModal'));
        modal.show();
      } else {
        alert("Gagal memproses transaksi: " + data.message);
      }
    })
    .catch(err => {
      btn.disabled = false;
      btn.innerHTML = `<i class="bi bi-credit-card-fill me-1"></i> Selesaikan Transaksi`;
      console.error(err);
      alert("Terjadi kesalahan sistem.");
    });
  }

  function resetPOS() {
    clearCart();
    // Reload page to refresh catalog stocks
    window.location.reload();
  }
</script>

<%- include('../partials/footer') %>
