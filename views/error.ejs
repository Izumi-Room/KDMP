<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error - AIWarung</title>
  <!-- Bootstrap 5 CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    body {
      background-color: #f8fafc;
      font-family: system-ui, -apple-system, sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  </style>
</head>
<body>
  <div class="container text-center">
    <div class="card border-0 shadow-sm rounded-4 p-5 mx-auto" style="max-width: 500px; background: white;">
      <div class="text-danger mb-4">
        <i class="bi bi-exclamation-triangle-fill" style="font-size: 64px;"></i>
      </div>
      <h1 class="h3 text-dark mb-2"><%= error.status || 500 %></h1>
      <p class="text-secondary mb-4"><%= message %></p>
      <% if (error.stack) { %>
        <pre class="text-start bg-light p-3 rounded-3 overflow-auto" style="font-size: 11px; max-height: 180px;"><%= error.stack %></pre>
      <% } %>
      <a href="/" class="btn btn-primary px-4 rounded-pill">
        <i class="bi bi-house-door-fill me-1"></i>
        Kembali ke Dashboard
      </a>
    </div>
  </div>
</body>
</html>
