<%- include('../../partials/header') %>
<%- include('../../partials/sidebar') %>

<div class="main-wrapper">
  <div class="page-header-nav">
    <div>
      <h1 class="h3 fw-bold mb-0">Mitra Supplier</h1>
      <p class="text-secondary mb-0" style="font-size: 14px;">Administrasi vendor supplier mitra penyedia stock barang</p>
    </div>
    <div>
      <a href="/admin-umkm/supplier/create" class="btn btn-primary-custom d-flex align-items-center gap-2">
        <i class="bi bi-plus-circle"></i>
        <span>Tambah Supplier</span>
      </a>
    </div>
  </div>

  <%- include('../../partials/alerts') %>

  <!-- Search area -->
  <div class="glass-card p-3 mb-4 fade-in">
    <form action="/admin-umkm/supplier" method="GET" class="row g-3 align-items-center">
      <div class="col-md-6 col-lg-4">
        <div class="input-group">
          <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-secondary"></i></span>
          <input type="text" name="search" class="form-control form-control-custom border-start-0 ps-0" placeholder="Cari nama supplier atau kode..." value="<%= search %>">
        </div>
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-primary-custom">Filter</button>
        <% if (search) { %>
          <a href="/admin-umkm/supplier" class="btn btn-outline-secondary ms-1" style="border-radius: 8px; padding: 10px 20px;">Reset</a>
        <% } %>
      </div>
    </form>
  </div>

  <!-- Supplier Table -->
  <div class="glass-card fade-in">
    <div class="table-responsive">
      <table class="table custom-table mb-0">
        <thead>
          <tr>
            <th>No</th>
            <th>Kode Supplier</th>
            <th>Nama Supplier</th>
            <th>Alamat Mitra</th>
            <th>NPWP Vendor</th>
            <th class="text-end">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (suppliers.length === 0) { %>
            <tr>
              <td colspan="6" class="text-center text-muted">Belum ada mitra supplier terdaftar.</td>
            </tr>
          <% } else { %>
            <% suppliers.forEach((sup, index) => { %>
              <% const num = (currentPage - 1) * 10 + index + 1; %>
              <tr>
                <td><%= num %></td>
                <td class="fw-semibold text-primary"><%= sup.kode_supplier %></td>
                <td class="fw-bold text-dark"><%= sup.nama_supplier %></td>
                <td><%= sup.alamat || '-' %></td>
                <td><%= sup.npwp || '-' %></td>
                <td class="text-end">
                  <div class="d-flex justify-content-end gap-2">
                    <a href="/admin-umkm/supplier/<%= sup.id %>/edit" class="btn btn-outline-warning btn-sm border-0" data-bs-toggle="tooltip" title="Edit Supplier">
                      <i class="bi bi-pencil-square"></i>
                    </a>
                    <form action="/admin-umkm/supplier/<%= sup.id %>/delete" method="POST" onsubmit="return confirm('Apakah Anda yakin ingin menghapus supplier ini?');" class="m-0">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="btn btn-outline-danger btn-sm border-0" data-bs-toggle="tooltip" title="Hapus Supplier">
                        <i class="bi bi-trash-fill"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Pagination Footer -->
    <% if (totalPages > 1) { %>
      <div class="card-footer bg-white border-0 py-3 d-flex justify-content-center">
        <nav aria-label="Page navigation">
          <ul class="pagination pagination-sm mb-0">
            <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
              <a class="page-link" href="/admin-umkm/supplier?page=<%= currentPage - 1 %>&search=<%= search %>">Sebelumnya</a>
            </li>
            <% for(let i = 1; i <= totalPages; i++) { %>
              <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                <a class="page-link" href="/admin-umkm/supplier?page=<%= i %>&search=<%= search %>"><%= i %></a>
              </li>
            <% } %>
            <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
              <a class="page-link" href="/admin-umkm/supplier?page=<%= currentPage + 1 %>&search=<%= search %>">Selanjutnya</a>
            </li>
          </ul>
        </nav>
      </div>
    <% } %>
  </div>
</div>

<%- include('../../partials/footer') %>
