<%- include('../../partials/header') %>
<%- include('../../partials/sidebar') %>

<div class="main-wrapper">
  <div class="page-header-nav">
    <div>
      <h1 class="h3 fw-bold mb-0">Tambah Barang</h1>
      <p class="text-secondary mb-0" style="font-size: 14px;">Menambahkan barang baru ke dalam katalog stok warung</p>
    </div>
    <div>
      <a href="/admin-umkm/barang" class="btn btn-outline-secondary d-flex align-items-center gap-2" style="border-radius: 8px; padding: 10px 20px;">
        <i class="bi bi-arrow-left"></i>
        <span>Kembali</span>
      </a>
    </div>
  </div>

  <div class="row fade-in">
    <div class="col-12 col-md-10 col-lg-8 col-xl-7">
      <div class="glass-card p-4">
        <%- include('../../partials/alerts') %>

        <form action="/admin-umkm/barang" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="mb-3">
            <label class="form-label fw-semibold text-secondary">Kode Barang (Unique)</label>
            <input type="text" name="kode_barang" class="form-control form-control-custom <%= errors.kode_barang ? 'is-invalid' : '' %>" value="<%= old.kode_barang || '' %>" required placeholder="Contoh: BRG-005">
            <% if (errors.kode_barang) { %>
              <div class="invalid-feedback"><%= errors.kode_barang %></div>
            <% } %>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold text-secondary">Nama Barang</label>
            <input type="text" name="nama_barang" class="form-control form-control-custom <%= errors.nama_barang ? 'is-invalid' : '' %>" value="<%= old.nama_barang || '' %>" required placeholder="Contoh: Mie Instan Kuah Kari">
            <% if (errors.nama_barang) { %>
              <div class="invalid-feedback"><%= errors.nama_barang %></div>
            <% } %>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold text-secondary">Ukuran / Dimensi (Opsional)</label>
            <input type="text" name="ukuran" class="form-control form-control-custom <%= errors.ukuran ? 'is-invalid' : '' %>" value="<%= old.ukuran || '' %>" placeholder="Contoh: 75g, 1 Liter, 5kg">
            <% if (errors.ukuran) { %>
              <div class="invalid-feedback"><%= errors.ukuran %></div>
            <% } %>
          </div>

          <div class="row mb-4">
            <div class="col-md-6">
              <label class="form-label fw-semibold text-secondary">Stok Awal</label>
              <input type="number" name="stok" class="form-control form-control-custom <%= errors.stok ? 'is-invalid' : '' %>" value="<%= old.stok || '0' %>" required min="0">
              <% if (errors.stok) { %>
                <div class="invalid-feedback"><%= errors.stok %></div>
              <% } %>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold text-secondary">Satuan Ukur</label>
              <input type="text" name="satuan" class="form-control form-control-custom <%= errors.satuan ? 'is-invalid' : '' %>" value="<%= old.satuan || '' %>" required placeholder="Contoh: Pcs, Karung, Pak, Botol">
              <% if (errors.satuan) { %>
                <div class="invalid-feedback"><%= errors.satuan %></div>
              <% } %>
            </div>
          </div>

          <button type="submit" class="btn btn-primary-custom w-100 py-3 fw-semibold">
            <i class="bi bi-save me-1"></i> Simpan Barang
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
