<%- include('../../partials/header') %>
<%- include('../../partials/sidebar') %>

<div class="main-wrapper">
  <div class="page-header-nav">
    <div>
      <h1 class="h3 fw-bold mb-0">Detail Pegawai</h1>
      <p class="text-secondary mb-0" style="font-size: 14px;">Informasi lengkap data diri dan hak akses pegawai</p>
    </div>
    <div>
      <a href="/admin-umkm/user" class="btn btn-outline-secondary d-flex align-items-center gap-2" style="border-radius: 8px; padding: 10px 20px;">
        <i class="bi bi-arrow-left"></i>
        <span>Kembali</span>
      </a>
    </div>
  </div>

  <div class="row fade-in mt-4">
    <div class="col-12 col-md-10 col-lg-8 col-xl-7">
      <div class="glass-card p-4">
        <%- include('../../partials/alerts') %>

        <div class="d-flex align-items-center gap-4 mb-4 pb-4 border-bottom">
          <div class="bg-primary text-white d-flex align-items-center justify-content-center rounded-circle" style="width: 72px; height: 72px; font-size: 32px;">
            <i class="bi bi-person-fill"></i>
          </div>
          <div>
            <h2 class="h4 fw-bold text-dark mb-1"><%= employee.name %></h2>
            <span class="badge bg-primary-subtle text-primary px-3 py-2" style="font-size: 13px;">
              <%= employee.role?.name || 'Tidak ada posisi' %>
            </span>
          </div>
        </div>

        <div class="row g-3">
          <div class="col-sm-6">
            <label class="form-label fw-bold text-secondary mb-1" style="font-size: 12px; letter-spacing: 0.5px; text-transform: uppercase;">Username (ID Login)</label>
            <p class="fs-6 text-dark fw-medium mb-0"><%= employee.username %></p>
          </div>

          <div class="col-sm-6">
            <label class="form-label fw-bold text-secondary mb-1" style="font-size: 12px; letter-spacing: 0.5px; text-transform: uppercase;">Email Address</label>
            <p class="fs-6 text-dark fw-medium mb-0"><%= employee.email || '-' %></p>
          </div>

          <div class="col-sm-6">
            <label class="form-label fw-bold text-secondary mb-1" style="font-size: 12px; letter-spacing: 0.5px; text-transform: uppercase;">Status Akun</label>
            <div>
              <span class="badge bg-<%= employee.status ? 'success' : 'danger' %>-subtle text-<%= employee.status ? 'success' : 'danger' %> px-2 py-1">
                <%= employee.status ? 'Aktif' : 'Nonaktif' %>
              </span>
            </div>
          </div>

          <div class="col-sm-6">
            <label class="form-label fw-bold text-secondary mb-1" style="font-size: 12px; letter-spacing: 0.5px; text-transform: uppercase;">Terdaftar Pada</label>
            <p class="fs-6 text-dark fw-medium mb-0">
              <%= new Date(employee.createdAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
            </p>
          </div>

          <div class="col-12 mt-4 pt-3 border-top d-flex gap-2">
            <a href="/admin-umkm/user/<%= employee.id %>/edit" class="btn btn-primary-custom flex-grow-1 py-2 fw-semibold">
              <i class="bi bi-pencil-square me-1"></i> Edit Data Pegawai
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
