<%- include('../../partials/header') %>
<%- include('../../partials/sidebar') %>

<div class="main-wrapper">
  <div class="page-header-nav">
    <div>
      <h1 class="h3 fw-bold mb-0">Laporan Pembelian</h1>
      <p class="text-secondary mb-0" style="font-size: 14px;">Rekapitulasi pengeluaran restok dan pembelian barang bulanan</p>
    </div>
  </div>

  <%- include('../../partials/alerts') %>

  <!-- Filters Area -->
  <div class="glass-card p-4 mb-4 fade-in">
    <form action="/admin-umkm/laporan/pembelian" method="GET">
      <div class="row g-3 align-items-end">
        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
          <label class="form-label fw-semibold text-secondary">Pilih Bulan</label>
          <select name="bulan" class="form-select form-control-custom">
            <% Object.keys(months).forEach(num => { %>
              <option value="<%= num %>" <%= parseInt(num, 10) === bulan ? 'selected' : '' %>><%= months[num] %></option>
            <% }) %>
          </select>
        </div>

        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
          <label class="form-label fw-semibold text-secondary">Pilih Tahun</label>
          <select name="tahun" class="form-select form-control-custom">
            <% years.forEach(yr => { %>
              <option value="<%= yr %>" <%= yr === tahun ? 'selected' : '' %>><%= yr %></option>
            <% }) %>
          </select>
        </div>

        <div class="col-12 col-sm-auto">
          <button type="submit" class="btn btn-primary-custom w-100">
            <i class="bi bi-funnel me-1"></i> Filter
          </button>
        </div>
      </div>

      <!-- Export buttons row -->
      <div class="d-flex flex-wrap gap-2 mt-3 pt-3 border-top">
        <a href="/admin-umkm/laporan/pembelian/export-pdf?bulan=<%= bulan %>&tahun=<%= tahun %>" class="btn btn-danger d-flex align-items-center gap-2" style="border-radius: 8px;">
          <i class="bi bi-file-earmark-pdf-fill"></i>
          <span>Unduh PDF</span>
        </a>
        <a href="/admin-umkm/laporan/pembelian/export-excel?bulan=<%= bulan %>&tahun=<%= tahun %>" class="btn btn-success d-flex align-items-center gap-2" style="border-radius: 8px;">
          <i class="bi bi-file-earmark-excel-fill"></i>
          <span>Unduh Excel</span>
        </a>
      </div>
    </form>
  </div>

  <!-- Report Data Table -->
  <div class="glass-card fade-in">
    <div class="table-responsive">
      <table class="table custom-table mb-0">
        <thead>
          <tr>
            <th>No</th>
            <th>Tanggal</th>
            <th>No Faktur</th>
            <th>Supplier</th>
            <th>Pegawai Restok</th>
            <th>Detail Barang Restok (Qty)</th>
            <th class="text-end">Total Pembelian</th>
          </tr>
        </thead>
        <tbody>
          <% if (report.length === 0) { %>
            <tr>
              <td colspan="7" class="text-center text-muted">Tidak ada transaksi pembelian/restok pada bulan ini.</td>
            </tr>
          <% } else { %>
            <% let grandTotal = 0; %>
            <% report.forEach((purchase, index) => { %>
              <% grandTotal += parseFloat(purchase.total_harga); %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= purchase.tanggal %></td>
                <td class="fw-semibold text-primary"><%= purchase.no_faktur %></td>
                <td class="fw-semibold"><%= purchase.supplier?.nama_supplier || '-' %></td>
                <td><%= purchase.user?.name || '-' %></td>
                <td>
                  <ul class="list-unstyled mb-0" style="font-size: 13px;">
                    <% purchase.details.forEach(det => { %>
                      <li><i class="bi bi-caret-right-fill text-muted me-1"></i><%= det.barang?.nama_barang || 'Barang Dihapus' %> (<%= det.qty %> <%= det.barang?.satuan || 'pcs' %>)</li>
                    <% }) %>
                  </ul>
                </td>
                <td class="text-end fw-bold text-danger">
                  Rp <%= Number(purchase.total_harga).toLocaleString('id-ID') %>
                </td>
              </tr>
            <% }) %>
            <tr class="bg-light">
              <td colspan="6" class="text-end fw-bold">Total Pengeluaran Bulanan:</td>
              <td class="text-end fw-bold text-danger" style="font-size: 16px;">
                Rp <%= Number(grandTotal).toLocaleString('id-ID') %>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
